{
  "manifest_version": 3,
  "name": "Curator",
  "description": "在本地查询、浏览、移动和删除 Chrome 书签。",
  "version": "1.4.1",
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "favicon",
    "notifications",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/service-worker/service-worker.ts",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "src/assets/icon16.png",
      "24": "src/assets/icon24.png",
      "32": "src/assets/icon32.png"
    },
    "default_title": "Curator",
    "default_popup": "src/popup/popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/newtab.html"
  }
}
