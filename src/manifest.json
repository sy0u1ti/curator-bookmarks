{
  "manifest_version": 3,
  "name": "Curator",
  "description": "在本地查询、浏览、移动和删除 Chrome 书签。",
  "version": "1.4.10",
  "icons": {
    "16": "src/assets/icon16.png",
    "32": "src/assets/icon32.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "bookmarks",
    "favicon",
    "notifications",
    "storage",
    "webNavigation",
    "webRequest"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/service-worker/service-worker.ts",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "src/assets/icon16.png",
      "24": "src/assets/icon24.png",
      "32": "src/assets/icon32.png"
    },
    "default_title": "Curator",
    "default_popup": "src/popup/popup.html"
  },
  "commands": {
    "curator-capture-inbox": {
      "suggested_key": {
        "default": "Alt+Shift+I"
      },
      "description": "直接收藏当前网页到 Inbox / 待整理"
    },
    "curator-open-search": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "打开 Curator 并聚焦搜索"
    },
    "curator-open-smart-classifier": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "打开 Curator 并立即智能分类"
    },
    "curator-toggle-auto-analyze": {
      "description": "切换 Curator 自动分析"
    }
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/newtab.html"
  }
}
